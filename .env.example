PORT=3000
TIMEZONE=Asia/Calcutta
CLAW_DATA_DIR=./data

NVIDIA_API_KEY=
NVIDIA_MODEL=qwen/qwen3.5-397b-a17b
NVIDIA_MODELS=qwen/qwen3.5-397b-a17b,meta/llama-3.1-405b-instruct,mistralai/mistral-large-3-675b-instruct-2512,meta/llama-3.3-70b-instruct,mistralai/mistral-medium-3-instruct,meta/llama-4-maverick-17b-128e-instruct,qwen/qwen3-next-80b-a3b-instruct,google/gemma-3-27b-it,deepseek-ai/deepseek-v3.2,qwen/qwen2.5-coder-32b-instruct
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_TIMEOUT_MS=4200
NVIDIA_MAX_ATTEMPTS=10
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=5000
SEARCH_TIMEOUT_MS=1800
REPLY_LATENCY_BUDGET_MS=6200

WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_GRAPH_VERSION=v22.0
WHATSAPP_APP_SECRET=
WHATSAPP_PROVIDER=meta
WHATSAPP_AUTO_REPLY=true

# Set WHATSAPP_PROVIDER=aisensy to send outbound replies through an AiSensy
# API Campaign. The campaign template should contain one dynamic text variable
# for the AI reply, such as: {{1}}
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=
AISENSY_API_URL=https://backend.aisensy.com/campaign/t1/api/v2
AISENSY_SOURCE=Claw Cloud AI
AISENSY_DEFAULT_USER_NAME=WhatsApp user
AISENSY_FLOW_TOKEN=

BOT_NAME=Claw Cloud
APP_BASE_URL=
ADMIN_API_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_CONTACTS_SCOPE=https://www.googleapis.com/auth/contacts.readonly

REMINDER_POLL_INTERVAL_MS=15000
MAX_CONVERSATION_MESSAGES=40
